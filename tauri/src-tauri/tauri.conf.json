{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MusicSync",
  "version": "0.1.0",
  "identifier": "dev.musicsync.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "MusicSync",
        "width": 1100,
        "height": 700,
        "minWidth": 700,
        "minHeight": 500,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "category": "Music"
  }
}
